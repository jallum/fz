+fn collect_reachable_dispatch_input_scopes(
+    world: &mut World<'_>,
+    plan: &DispatchPlan,
+    node_id: GraphNodeId,
+    subjects: &HashMap<SubjectId, Ty>,
+    input_subjects: &[(usize, SubjectId)],
+    scopes: &mut BTreeMap<u32, Vec<Option<Ty>>>,
+) {
+    let Some(node) = plan.graph.node(node_id) else {
+        return;
+    };
+    match node {
+        DispatchNode::Fail => {}
+        DispatchNode::Outcome { outcome, .. } => {
+            let body_id = plan
+                .outcome(*outcome)
+                .map(|entry| entry.body_id)
+                .unwrap_or_else(|| panic!("dispatch outcome {outcome:?} should map to a body id"));
+            let entry = scopes.entry(body_id).or_insert_with(|| vec![None; plan.input_count]);
+            for &(ordinal, subject_id) in input_subjects {
+                let Some(observed) = subjects.get(&subject_id).copied() else {
+                    continue;
+                };
+                entry[ordinal] = Some(match entry[ordinal] {
+                    Some(current) => merge_observed_ty(world, current, observed),
+                    None => observed,
+                });
+            }
+        }
+        DispatchNode::Test {
+            predicate,
+            on_match,
+            on_miss,
+        } => {
+            let source = subjects
+                .get(&predicate.subject)
+                .cloned()
+                .unwrap_or_else(|| any_ty(world));
+            if branch_possible(world, predicate, &source, true) {
+                let mut next = subjects.clone();
+                apply_evidence(world, plan, &mut next, &source, predicate, &on_match.evidence, true);
+                collect_reachable_dispatch_input_scopes(
+                    world,
+                    plan,
+                    on_match.target,
+                    &next,
+                    input_subjects,
+                    scopes,
+                );
+            }
+            if branch_possible(world, predicate, &source, false) {
+                let mut next = subjects.clone();
+                apply_evidence(world, plan, &mut next, &source, predicate, &on_miss.evidence, false);
+                collect_reachable_dispatch_input_scopes(
+                    world,
+                    plan,
+                    on_miss.target,
+                    &next,
+                    input_subjects,
+                    scopes,
+                );
+            }
+        }
+    }
+}
