+fn reachable_dispatch_input_scopes(
+    world: &mut World<'_>,
+    plan: &DispatchPlan,
+    inputs: &[Ty],
+) -> BTreeMap<u32, Vec<Option<Ty>>> {
+    let input_subjects = (0..plan.input_count)
+        .map(|ordinal| {
+            let subject_id = plan
+                .matrix
+                .subjects
+                .iter()
+                .find_map(|subject| match subject.source {
+                    SubjectSource::Input { ordinal: input_ordinal } if input_ordinal as usize == ordinal => {
+                        Some(subject.id)
+                    }
+                    _ => None,
+                })
+                .unwrap_or_else(|| panic!("dispatch input subject {ordinal} should exist"));
+            (ordinal, subject_id)
+        })
+        .collect::<Vec<_>>();
+
+    let mut subjects = HashMap::new();
+    for &(ordinal, subject_id) in &input_subjects {
+        let input = inputs.get(ordinal).cloned().unwrap_or_else(|| any_ty(world));
+        subjects.insert(subject_id, input);
+    }
+
+    let mut scopes = BTreeMap::<u32, Vec<Option<Ty>>>::new();
+    collect_reachable_dispatch_input_scopes(world, plan, plan.graph.root, &subjects, &input_subjects, &mut scopes);
+    scopes
