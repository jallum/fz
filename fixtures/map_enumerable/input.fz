fn main() do
  map = %{3 => :three, 1 => :one, 2 => :two}
  ints = %{2 => 20, 1 => 10}

  dbg(Enumerable.reduce(map, {:cont, []}, fn (pair, acc) -> {:cont, [pair | acc]} end))
  dbg(Enumerable.reduce(ints, {:cont, 0}, fn ({_key, value}, acc) -> {:cont, acc + value} end))
  dbg(Enumerable.reduce(map, {:halt, 99}, fn (pair, acc) -> {:cont, [pair | acc]} end))

  dbg(Enumerable.count(map))
  dbg(Enumerable.member?(map, {1, :one}))
  dbg(Enumerable.member?(map, {1, :two}))
  dbg(Enumerable.member?(map, 1))
  {:ok, n, slicer} = Enumerable.slice(map)
  dbg(n)
  dbg(slicer.(map))
end
