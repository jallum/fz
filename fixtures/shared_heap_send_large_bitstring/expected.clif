    v13 = call fn3(v10, v11, v12)       ; @6:16  v10 = 3, v11 = 1, v12 = 0
    v14 = func_addr.i64 fn4             ; @6:16
    store notrap aligned v14, v13+16    ; @6:16
    store notrap aligned v8, v13+24     ; @6:16
    v15 = call fn5(v13)                 ; @6:19
    v16 = iconst.i32 4                  ; @8:9
    v17 = iconst.i32 2                  ; @8:9
    v18 = iconst.i32 0                  ; @8:9
    v19 = call fn6(v16, v17, v18)       ; @8:9  v16 = 4, v17 = 2, v18 = 0
    v20 = func_addr.i64 fn7             ; @8:9
    store notrap aligned v20, v19+16    ; @8:9
