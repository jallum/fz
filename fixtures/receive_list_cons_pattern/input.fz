fn main() do
  send(self(), [10, 20, 30])
  send(self(), [])
  send(self(), :stop)

  a = receive do
    [h | _] -> h
    [] -> -1
    _ -> 0
  end

  b = receive do
    [h | _] -> h
    [] -> -1
    _ -> 0
  end

  c = receive do
    [h | _] -> h
    [] -> -1
    _ -> 0
  end

  print({a, b, c})
end
