# purpose: multi-clause dispatch with a guard, plus recursive `fact` — currently deferred on `# paths: ` because guard lowering is not yet wired
# paths:   
# defer:   fz-ul4.24 (guard clauses in ir_lower)

fn classify(0), do: :zero
fn classify(n) when n > 0, do: :positive
fn classify(_), do: :negative

fn fact(0), do: 1
fn fact(n), do: n * fact(n - 1)

fn main() do
  print(classify(0))
  print(classify(7))
  print(classify(-3))
  print(fact(5))
end
