defmodule MathTest do
  fn helper(x), do: x * 2

  test(:test_helper) do
    assert(helper(21) == 42)
  end

  test(:test_arithmetic) do
    assert(1 + 1 == 2)
    assert(40 + 2 == 42)
  end
end

defmodule AtomTest do
  test(:test_eq) do
    assert(:ok == :ok)
  end

  test(:test_neq) do
    refute(:ok == :error)
  end
end