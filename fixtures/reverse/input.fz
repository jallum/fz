fn reverse(xs), do: reverse_into(xs, [])

fn reverse_into([], acc), do: acc
fn reverse_into([h | t], acc), do: reverse_into(t, [h | acc])

fn main() do
  out = reverse([1, 2, 3, 4, 5])
  print(out)

  stats = Process.heap_alloc_stats()
  print(stats)
  heap_bytes = stats[:list_cons_bytes] + stats[:struct_bytes] + stats[:map_bytes]
  print(heap_bytes)
end
