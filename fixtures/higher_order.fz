# purpose: higher-order patterns — apply2, compose
# paths:   jit, interp, aot
# expect_clif_contains: k_5_s12: (RawInt, Tagged, Tagged, RawInt) -> RawInt
# expect_clif_excludes: k_5_s12: sshr_imm

fn double(x), do: x * 2
fn neg(x), do: 0 - x
fn apply2(f, x), do: f(x)
fn compose(f, g, x), do: f(g(x))

fn main() do
  print(apply2(double, 21))
  print(apply2(neg, 7))
  print(compose(double, neg, 5))
end
