    fn0 = u0:1 sig0
    fn1 = u0:1 sig1

    block0(v0: i64, v1: i64):    ;; v0 :: nil
    v2 = iconst.i64 93                  ; @3:9
    call fn0(v2)                        ; @3:15  v2 = 93
    v3 = iconst.i64 3                   ; @3:15
