# purpose: 100k-deep self-recursion must TCO — exits cleanly with the accumulated count
# paths:   jit, interp, aot
# expect_clif_excludes: count_s2: ishl_imm
# expect_clif_excludes: count_s2: bor_imm
# expect_clif_excludes: count_s3: ishl_imm
# expect_clif_excludes: count_s3: bor_imm
# expect_clif_excludes: k_2_s4: sshr_imm

fn count(0, acc), do: acc
fn count(n, acc), do: count(n - 1, acc + 1)

fn main() do
  print(count(100000, 0))
end
