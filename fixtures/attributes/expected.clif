; fn main
    ;   @spec   main() -> _
    ;   @key    []
    ;   @abi    () -> Tagged
function u0:0(i64) -> i64 tail {
    sig0 = (i64, i64) -> i64 tail
    sig1 = (i64, i64) -> i64 tail
    sig2 = (i32, i32, i32) -> i64 system_v
    fn0 = colocated u0:46 sig0
    fn1 = colocated u0:48 sig1
    fn2 = u0:31 sig2

block0(v0: i64):
    v1 = iconst.i64 10                  ; @12:20
    v2 = iconst.i32 5                   ; @12:9
    v3 = iconst.i32 1                   ; @12:9
    v4 = iconst.i32 0                   ; @12:9
    v5 = call fn2(v2, v3, v4)           ; @12:9  v2 = 5, v3 = 1, v4 = 0
    v6 = func_addr.i64 fn1              ; @12:9
    store notrap aligned v6, v5+16      ; @12:9
    store notrap aligned v0, v5+24      ; @12:9
    return_call fn0(v1, v5)             ; @12:9  v1 = 10
}

; fn Greeter.hi_s3
    ;   @spec   Greeter.hi(:alice) -> :alice
    ;   @key    [:alice]
    ;   @abi    (Tagged) -> Tagged
function u0:0(i64, i64) -> i64 tail {
    sig0 = (i64, i64) -> i64 tail

    block0(v0: i64, v1: i64):    ;; v0 :: :alice
    v2 = load.i64 notrap aligned v1+16
    return_call_indirect sig0, v2(v0, v1)
}

