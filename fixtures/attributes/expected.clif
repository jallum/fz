    ;   @abi    (Tagged) -> Tagged
function u0:0(i64, i64) -> i64 tail {
    sig0 = (i64) system_v
    sig1 = (i64, i64) -> i64 tail
    sig2 = (i64, i64) -> i64 tail
    sig3 = (i32, i32, i32) -> i64 system_v
    fn0 = u0:0 sig0
    fn1 = colocated u0:47 sig1
    fn2 = colocated u0:49 sig2
    fn3 = u0:31 sig3

    block0(v0: i64, v1: i64):    ;; v0 :: :alice
    call fn0(v0)                        ; @12:3
    v2 = iconst.i64 3                   ; @12:3
    v3 = iconst.i64 42                  ; @13:22
    v4 = iconst.i32 6                   ; @13:9
    v5 = iconst.i32 1                   ; @13:9
    v6 = iconst.i32 0                   ; @13:9
    v7 = call fn3(v4, v5, v6)           ; @13:9  v4 = 6, v5 = 1, v6 = 0
    v8 = func_addr.i64 fn2              ; @13:9
    store notrap aligned v8, v7+16      ; @13:9
    v9 = load.i64 notrap aligned v1+24  ; @13:9
    store notrap aligned v9, v7+24      ; @13:9
    return_call fn1(v3, v7)             ; @13:9  v3 = 42
}

; fn k_4_s6
    ;   @spec   k_4(42) -> nil
    ;   @key    [42]
    ;   @abi    (RawInt) -> Tagged
function u0:0(i64, i64) -> i64 tail {
    sig0 = (i64) system_v
    sig1 = (i64, i64) -> i64 tail
    fn0 = u0:1 sig0

    block0(v0: i64, v1: i64):    ;; v0 :: 42
