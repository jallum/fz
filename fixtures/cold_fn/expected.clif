; fn main
    ;   @spec   main() -> nil
    ;   @key    []
    ;   @abi    () -> Tagged
function u0:0(i64) -> i64 tail {
    sig0 = (i64) system_v
    sig1 = (i64, i64) -> i64 tail
    fn0 = u0:1 sig0

block0(v0: i64):
    v3 = iconst.i64 14                  ; @2:27
    v4 = ishl_imm v3, 3                 ; @2:22  v3 = 14
    v5 = bor_imm v4, 1                  ; @2:22
    jump block1(v5)                     ; @2:22

    block1(v1: i64):    ;; v1 :: 14
    v6 = iconst.i64 3    ;; v6 :: 3
    v7 = sshr_imm v1, 3
    v8 = imul v7, v6  ; v6 = 3
    v9 = ishl_imm v8, 3
    v10 = bor_imm v9, 1    ;; v10 :: int
    jump block2(v10)

    block2(v2: i64):    ;; v2 :: int
    v11 = sshr_imm v2, 3
    call fn0(v11)
    v12 = iconst.i64 3    ;; v12 :: nil
    v13 = load.i64 notrap aligned v0+16
    return_call_indirect sig1, v13(v12, v0)  ; v12 = 3
}

