function u0:0(i64) -> i64 tail {
    sig0 = (i64, i64, i64) -> i64 tail
    sig1 = (i64, i64) -> i64 tail
    sig2 = (i32, i32) -> i64 system_v
    fn0 = colocated u0:47 sig0
    fn1 = colocated u0:50 sig1
    fn2 = u0:31 sig2

block0(v0: i64):
    v1 = iconst.i64 10                  ; @30:23
    v2 = iconst.i64 20                  ; @30:27
    v3 = iconst.i32 9                   ; @30:16
    v4 = iconst.i32 1                   ; @30:16
    v5 = call fn2(v3, v4)               ; @30:16  v3 = 9, v4 = 1
    v6 = func_addr.i64 fn1              ; @30:16
    store notrap aligned v6, v5+16      ; @30:16
    store notrap aligned v0, v5+24      ; @30:16
    return_call fn0(v1, v2, v5)         ; @30:16  v1 = 10, v2 = 20
