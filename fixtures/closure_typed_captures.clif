; fn lambda_3_s8
    ;   @spec   lambda_3(10, 20, any) -> int | float
    ;   @key    [10, 20, any]
    ;   @abi    (RawInt, RawInt, Tagged) -> Tagged
function u0:0(i64, i64, i64) -> i64 tail {
    sig0 = (i64) -> f64 system_v
    sig1 = (i64) -> i64 system_v
    sig2 = (f64, f64) -> f64 system_v
    sig3 = (i64, i64) -> i64 tail
    fn0 = u0:24 sig0
    fn1 = u0:23 sig1
    fn2 = u0:25 sig2

    block0(v0: i64, v1: i64, v2: i64):    ;; v0 :: any
    v3 = load.i64 notrap aligned v1+24    ;; v3 :: 10
    v4 = load.i64 notrap aligned v1+32    ;; v4 :: 20
    v5 = iadd v3, v4    ;; v5 :: int
    v6 = ishl_imm v5, 3
    v7 = bor_imm v6, 1
    v8 = bxor_imm v7, 1
    v9 = bxor_imm v0, 1
    v10 = bor v8, v9
    v11 = band_imm v10, 7
    v12 = icmp_imm eq v11, 0
    brif v12, block1, block2

block1:
    v14 = sshr_imm.i64 v7, 3
    v15 = sshr_imm.i64 v0, 3
    v16 = iadd v14, v15
    v17 = ishl_imm v16, 3
    v18 = bor_imm v17, 1
    jump block3(v18)

block2:
    v19 = call fn0(v7)
    v20 = call fn0(v0)
    v21 = fadd v19, v20
    v22 = bitcast.i64 v21
    v23 = call fn1(v22)
    jump block3(v23)

    block3(v13: i64):    ;; v13 :: int | float
    v24 = load.i64 notrap aligned v2+16
    return_call_indirect sig3, v24(v13, v2)
}

