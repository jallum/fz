    v2 = iconst.i64 34                  ; @6:15
    v3 = band_imm v2, 7  ; v2 = 34
    v4 = icmp_imm eq v3, 1
    v5 = iconst.i64 11
    v6 = iconst.i64 19
    v7 = select v4, v5, v6  ; v5 = 11, v6 = 19    ;; v7 :: :false
    v8 = iconst.i64 3                   ; @6:9
    v9 = iconst.i64 19                  ; @6:9
    v10 = icmp ne v7, v8                ; @6:9  v8 = 3
    v11 = icmp ne v7, v9                ; @6:9  v9 = 19
    v12 = band v10, v11                 ; @6:9
    brif v12, block2, block1            ; @6:9

block1:
    v13 = iconst.i64 26    ;; v13 :: :other
    call fn0(v13)  ; v13 = 26
    v14 = iconst.i64 3    ;; v14 :: nil
    v15 = load.i64 notrap aligned v1+16
    return_call_indirect sig1, v15(v14, v1)  ; v14 = 3

