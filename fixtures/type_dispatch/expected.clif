; fn main
    ;   @spec   main() -> _
    ;   @key    []
    ;   @abi    () -> Tagged
function u0:0(i64) -> i64 tail {
    sig0 = (i64, i64) -> i64 tail
    sig1 = (i64, i64) -> i64 tail
    fn0 = colocated u0:49 sig0
    fn1 = colocated u0:48 sig1

block0(v0: i64):
    v1 = iconst.i64 42                  ; @5:15
    v2 = ishl_imm v1, 3  ; v1 = 42
    v3 = bor_imm v2, 1
    v4 = band_imm v3, 7
    v5 = icmp_imm eq v4, 1
    v6 = iconst.i64 11
    v7 = iconst.i64 19
    v8 = select v5, v6, v7  ; v6 = 11, v7 = 19    ;; v8 :: :true
    v9 = iconst.i64 3                   ; @5:9
    v10 = iconst.i64 19                 ; @5:9
    v11 = icmp ne v8, v9                ; @5:9  v9 = 3
    v12 = icmp ne v8, v10               ; @5:9  v10 = 19
    v13 = band v11, v12                 ; @5:9
    brif v13, block2, block1            ; @5:9

block1:
    v14 = iconst.i64 26    ;; v14 :: :other
    return_call fn0(v14, v0)  ; v14 = 26

block2:
    v15 = iconst.i64 18    ;; v15 :: :is_int
    return_call fn1(v15, v0)  ; v15 = 18
}

