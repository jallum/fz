# purpose: `test()` inside a defmodule body
# kind:    test
# paths:   jit

defmodule MathTest do
  fn helper(x), do: x * 2

  test(:test_helper) do
    assert_eq(helper(21), 42)
  end

  test(:test_arithmetic) do
    assert_eq(1 + 1, 2)
    assert_eq(40 + 2, 42)
  end
end

defmodule AtomTest do
  test(:test_eq) do
    assert_eq(:ok, :ok)
  end

  test(:test_neq) do
    assert_neq(:ok, :error)
  end
end
