    sig0 = (i64, i64) -> i64 tail

    block0(v0: i64, v1: i64, v2: i64):    ;; v0 :: 10, v1 :: 32
    v3 = iadd v0, v1                    ; @2:21
    v4 = load.i64 notrap aligned v2+16
    return_call_indirect sig0, v4(v3, v2)
}

