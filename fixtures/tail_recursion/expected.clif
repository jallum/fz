    block0(v0: i64, v1: i64, v2: i64):    ;; v0 :: int, v1 :: int
    jump block1

block1:
    v3 = iconst.i64 0    ;; v3 :: 0
    v4 = icmp.i64 eq v0, v3  ; v3 = 0
    v5 = iconst.i64 11
    v6 = iconst.i64 19
    v7 = select v4, v5, v6  ; v5 = 11, v6 = 19    ;; v7 :: bool
    v8 = iconst.i64 3
    v9 = iconst.i64 19
    v10 = icmp ne v7, v8  ; v8 = 3
    v11 = icmp ne v7, v9  ; v9 = 19
    v12 = band v10, v11
    brif v12, block3, block2

block2:
    v13 = iconst.i64 1                  ; @2:33
    v14 = isub.i64 v0, v13              ; @2:29  v13 = 1
    v15 = iconst.i64 1                  ; @2:42
    v16 = iadd.i64 v1, v15              ; @2:36  v15 = 1
    return_call fn0(v14, v16, v2)       ; @2:23

block3:
    v17 = load.i64 notrap aligned v2+16
    return_call_indirect sig1, v17(v1, v2)
}

