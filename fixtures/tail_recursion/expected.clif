    v6 = call fn2(v3, v4, v5)           ; @5:9  v3 = 4, v4 = 1, v5 = 0
    v7 = func_addr.i64 fn1              ; @5:9
    store notrap aligned v7, v6+16      ; @5:9
    store notrap aligned v0, v6+24      ; @5:9
    return_call fn0(v1, v2, v6)         ; @5:9  v1 = 0x0001_86a0, v2 = 0
}

; fn count_s2
    ;   @spec   count(100000, 0) -> 0
    ;   @key    [100000, 0]
    ;   @abi    (RawInt, RawInt) -> RawInt
function u0:0(i64, i64, i64) -> i64 tail {
    sig0 = (i64, i64, i64) -> i64 tail
    sig1 = (i64, i64) -> i64 tail
    fn0 = colocated u0:48 sig0

    block0(v0: i64, v1: i64, v2: i64):    ;; v0 :: 100000, v1 :: 0
    jump block1

block1:
    v3 = iconst.i64 0    ;; v3 :: 0
    v4 = iconst.i64 19    ;; v4 :: :false
    v5 = iconst.i64 3
    v6 = iconst.i64 19
    v7 = icmp ne v4, v5  ; v4 = 19, v5 = 3
    v8 = icmp ne v4, v6  ; v4 = 19, v6 = 19
    v9 = band v7, v8
    brif v9, block3, block2

block2:
    v10 = iconst.i64 1                  ; @2:33
    v11 = isub.i64 v0, v10              ; @2:29  v10 = 1
    v12 = iconst.i64 1                  ; @2:42
    v13 = iadd.i64 v1, v12              ; @2:36  v12 = 1
    return_call fn0(v11, v13, v2)       ; @2:23

block3:
    v14 = load.i64 notrap aligned v2+16
    return_call_indirect sig1, v14(v1, v2)
}

; fn count_s3
    ;   @spec   count(int, int) -> int
    ;   @key    [int, int]
    ;   @abi    (RawInt, RawInt) -> RawInt
