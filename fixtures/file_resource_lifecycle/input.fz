extern "C" fn libc::creat(path :: cstring, mode :: integer) :: integer
extern "C" fn libc::close(integer) :: integer
extern "C" fn libc::unlink(cstring) :: integer

defmodule File do
  @type t :: opaque resource(integer)

  # Dtor body runs as fz code at task-exit (fz-4mk); we can call
  # libc::close directly and emit an observable side-effect so the test
  # can see the dtor fired.
  fn dtor(fd) do
    libc::close(fd)
    print(:dtor_closed)
  end

  fn wrap_fd(fd), do: make_resource(fd, &dtor/1)
  fn fd_of(h), do: h.value
end

fn main() do
  path = "/tmp/fz-file-resource-lifecycle"
  fd = libc::creat(path, 0o644)
  print(:opened)
  _h = File.wrap_fd(fd)
  libc::unlink(path)
  print(:before)
end
