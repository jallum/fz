fn catch(_), do: :anything
fn catch(0), do: :zero

fn cmatch(v) do
  case v do
    _ -> :anything
    0 -> :zero
  end
end

fn main() do
  assert(catch(0) == :anything, "fn: wildcard precedes specific, first-match-wins")
  assert(catch(7) == :anything, "fn: wildcard matches non-zero too")
  assert(cmatch(0) == :anything, "case: wildcard precedes specific, first-match-wins")
  assert(cmatch(99) == :anything, "case: wildcard matches non-zero too")
end
