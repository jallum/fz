fn filter_lt([], _), do: []
fn filter_lt([h | t], limit) when h < limit, do: [h | filter_lt(t, limit)]
fn filter_lt([_ | t], limit), do: filter_lt(t, limit)

fn main() do
  out = filter_lt([1, 5, 2, 8, 3], 4)
  dbg(out)

  stats = Process.heap_alloc_stats()
  dbg(stats)
  heap_bytes = stats[:list_cons_bytes] + stats[:struct_bytes] + stats[:map_bytes]
  dbg(heap_bytes)
end
