fn main() do
  send(self(), "hello")
  send(self(), "world")
  send(self(), :stop)

  a = receive do
    "hello" -> 1
    "world" -> 2
    _ -> 0
  end

  b = receive do
    "hello" -> 1
    "world" -> 2
    _ -> 0
  end

  c = receive do
    "hello" -> 1
    "world" -> 2
    _ -> 0
  end

  dbg({a, b, c})
end
