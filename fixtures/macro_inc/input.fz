defmacro inc(x) do
  quote do: unquote(x) + 1
end

defmacro double(x) do
  quote do: unquote(x) * 2
end

fn main() do
  assert(inc(41) == 42, "inc macro expands to +1")
  assert(double(21) == 42, "double macro expands to *2")
  assert(inc(double(20)) == 41, "nested macro expansion: double(20) then inc")
end
