extern "C" fn libc::creat(path :: cstring, mode :: integer) :: integer
extern "C" fn libc::write(integer, binary, integer) :: integer
extern "C" fn libc::unlink(cstring) :: integer

# Dtor lives in the runtime crate (fz-swt.13). It fcntl-verifies the fd is
# open, calls libc::close, fcntl-verifies the fd is now closed, and prints
# `dtor:closed`. We reuse it here instead of `&libc::close/1` because the
# runtime's resource hook resolves the dtor by extracting the closure's
# canonical Prim::Extern and invoking that symbol directly — anything else
# in the wrapper's body is never executed. The only way to *observe* the
# dtor fired is to have the dtor itself print.
extern "C" fn fz_test_close_fd(any) :: nil

defmodule FileHandle do
  @type t :: opaque resource(integer)

  fn from_fd(fd), do: make_resource(fd, &fz_test_close_fd/1)
end

fn main() do
  # "/tmp/fz-x5m" — created with mode 0o644 = 420
  path = <<47, 116, 109, 112, 47, 102, 122, 45, 120, 53, 109>>
  fd = libc::creat(path, 420)
  print(:opened)
  # "hi\n" — exercises the `binary` marshal class
  n = libc::write(fd, <<104, 105, 10>>, 3)
  print(n)
  _h = FileHandle.from_fd(fd)
  libc::unlink(path)
  print(:done)
end
