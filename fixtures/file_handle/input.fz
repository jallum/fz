extern "C" fn libc::creat(path :: cstring, mode :: integer) :: integer
extern "C" fn libc::write(integer, binary, integer) :: integer
extern "C" fn libc::close(integer) :: integer
extern "C" fn libc::unlink(cstring) :: integer

# Dtor body runs as real fz code at task-exit (fz-4mk). We can call
# libc::close directly AND print so the test can observe the dtor fired
# — the closure body is no longer extracted-then-discarded.
fn close_observable(fd) do
  libc::close(fd)
  print(:dtor_closed)
end

defmodule FileHandle do
  @type t :: opaque resource(integer)

  fn from_fd(fd), do: make_resource(fd, &close_observable/1)
end

fn main() do
  path = "/tmp/fz-x5m"
  fd = libc::creat(path, 0o644)
  print(:opened)
  n = libc::write(fd, "hi\n", 3)
  print(n)
  _h = FileHandle.from_fd(fd)
  libc::unlink(path)
  print(:done)
end
