    v7 = iconst.i64 3                   ; @12:3
    v8 = iconst.i64 7                   ; @13:23
    v9 = ishl_imm v8, 3                 ; @13:9  v8 = 7
    v10 = bor_imm v9, 1                 ; @13:9
    jump block1(v10)                    ; @13:9

