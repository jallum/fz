; fn main
    ;   @spec   main() -> _
    ;   @key    []
    ;   @abi    () -> Tagged
function u0:0(i64) -> i64 tail {
    sig0 = (i64, i64) -> i64 tail
    fn0 = colocated u0:43 sig0

block0(v0: i64):
    v2 = iconst.i64 7                   ; @12:17
    v3 = ishl_imm v2, 3                 ; @12:9  v2 = 7
    v4 = bor_imm v3, 1                  ; @12:9
    jump block1(v4)                     ; @12:9

    block1(v1: i64):    ;; v1 :: 7
    v5 = sshr_imm v1, 3
    return_call fn0(v5, v0)
}

; fn k_4
