# purpose: same call repeated — historical JIT tier-up trigger; today every call is JIT
# paths:   jit

fn hot(n), do: n + 1

fn main() do
  print(hot(0))
  print(hot(0))
  print(hot(0))
  print(hot(0))
  print(hot(0))
  print(hot(0))
  print(hot(0))
  print(hot(0))
  print(hot(0))
  print(hot(0))
end
