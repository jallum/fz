    v5 = load.i64 notrap aligned v1+56    ;; v5 :: {:let, :x, {:num, 1}, {:let, :x, {:num, 2}, {:var, :x}}}
    v6 = band_imm v0, 7
    v7 = icmp_imm eq v6, 1    ;; v7 :: bool
    brif v7, block2, block1             ; @32:3

block1:
    call fn0(v0)
    v8 = iconst.i64 3    ;; v8 :: nil
    v9 = load.i64 notrap aligned v1+24
    v10 = load.i64 notrap aligned v9+16
    return_call_indirect sig1, v10(v8, v9)  ; v8 = 3

block2:
    v11 = sshr_imm.i64 v0, 3
    call fn1(v11)
    v12 = iconst.i64 3    ;; v12 :: nil
    v13 = load.i64 notrap aligned v1+24
    v14 = load.i64 notrap aligned v13+16
    return_call_indirect sig3, v14(v12, v13)  ; v12 = 3
}

