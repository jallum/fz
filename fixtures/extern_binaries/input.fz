extern "C" fn fz_test_open_writeonly(cstring) :: integer
extern "C" fn fz_test_write_close(integer, binary, integer) :: integer

fn main() do
  # "/dev/null"
  path = <<47, 100, 101, 118, 47, 110, 117, 108, 108>>
  fd = fz_test_open_writeonly(path)
  # "hello"
  buf = <<104, 101, 108, 108, 111>>
  ok = fz_test_write_close(fd, buf, 5)
  print(ok)
end
