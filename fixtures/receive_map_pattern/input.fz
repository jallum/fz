fn main() do
  send(self(), %{name: :alice, age: 30})
  send(self(), %{name: :bob, age: 42})
  send(self(), :stop)

  a = receive do
    %{name: n} -> n
    _ -> :unknown
  end

  b = receive do
    %{name: n} -> n
    _ -> :unknown
  end

  c = receive do
    %{name: n} -> n
    _ -> :unknown
  end

  dbg({a, b, c})
end
