    call fn0(v0)                        ; @5:3
    v5 = iconst.i64 3                   ; @5:3
    v6 = iconst.i64 7                   ; @6:18
    v7 = ishl_imm v6, 3                 ; @6:9  v6 = 7
    v8 = bor_imm v7, 1                  ; @6:9
    jump block1(v8)                     ; @6:9

