    fn0 = u0:0 sig0
    fn1 = u0:0 sig1
    fn2 = u0:0 sig3

    block0(v0: i64, v1: i64):    ;; v0 :: :zero
    call fn0(v0)                        ; @5:3
    v2 = iconst.i64 3                   ; @5:3
    v3 = iconst.i64 7                   ; @6:18
    v4 = iconst.i64 0    ;; v4 :: 0
    v5 = iconst.i64 19    ;; v5 :: :false
    v6 = iconst.i64 3                   ; @6:9
    v7 = iconst.i64 19                  ; @6:9
    v8 = icmp ne v5, v6                 ; @6:9  v5 = 19, v6 = 3
    v9 = icmp ne v5, v7                 ; @6:9  v5 = 19, v7 = 19
    v10 = band v8, v9                   ; @6:9
    brif v10, block2, block1            ; @6:9

block1:
    v11 = iconst.i64 18    ;; v11 :: :other
    call fn1(v11)  ; v11 = 18
    v12 = iconst.i64 3    ;; v12 :: nil
    v13 = load.i64 notrap aligned v1+16
    return_call_indirect sig2, v13(v12, v1)  ; v12 = 3

block2:
    v14 = iconst.i64 10    ;; v14 :: :zero
