    v11 = iconst.i64 3
    v12 = iconst.i64 19
    v13 = icmp ne v10, v11  ; v10 = 19, v11 = 3
    v14 = icmp ne v10, v12  ; v10 = 19, v12 = 19
    v15 = band v13, v14
    brif v15, block4, block3

block3:
