    ;   @key    [any, pid, any]
    ;   @abi    (Tagged, Tagged, Tagged) -> Tagged
function u0:0(i64, i64) -> i64 tail {
    sig0 = (i64) system_v
    sig1 = (i64, i64) -> i64 tail
    sig2 = (i64) system_v
    sig3 = (i64, i64) -> i64 tail
    fn0 = u0:59 sig0
    fn1 = u0:60 sig2

    block0(v0: i64, v1: i64):    ;; v0 :: any
    v2 = band_imm v1, -8
    v3 = load.i64 notrap aligned v2+32    ;; v3 :: pid
    v4 = load.i64 notrap aligned v2+40    ;; v4 :: any
    v5 = band_imm v0, 7
    v6 = icmp_imm eq v5, 0    ;; v6 :: bool
    brif v6, block2, block1             ; @14:3

block1:
    call fn0(v0)
    v7 = iconst.i64 2    ;; v7 :: nil
    v8 = band_imm.i64 v1, -8
    v9 = load.i64 notrap aligned v8+24
    v10 = band_imm v9, -8
    v11 = load.i64 notrap aligned v10+16
    return_call_indirect sig1, v11(v7, v9)  ; v7 = 2

block2:
    v12 = sshr_imm.i64 v0, 3
    call fn1(v12)
    v13 = iconst.i64 2    ;; v13 :: nil
    v14 = band_imm.i64 v1, -8
    v15 = load.i64 notrap aligned v14+24
    v16 = band_imm v15, -8
    v17 = load.i64 notrap aligned v16+16
    return_call_indirect sig3, v17(v13, v15)  ; v13 = 2
}

