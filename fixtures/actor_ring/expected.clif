    sig1 = (i64, i64) -> i64 tail
    sig2 = (i64) system_v
    sig3 = (i64, i64) -> i64 tail
    fn0 = u0:59 sig0
    fn1 = u0:60 sig2

    block0(v0: i64, v1: i64):    ;; v0 :: any
    v2 = load.i64 notrap aligned v1+32    ;; v2 :: pid
    v3 = load.i64 notrap aligned v1+40    ;; v3 :: any
    v4 = band_imm v0, 7
    v5 = icmp_imm eq v4, 1    ;; v5 :: bool
    brif v5, block2, block1             ; @14:3

block1:
    call fn0(v0)
    v6 = iconst.i64 3    ;; v6 :: nil
    v7 = load.i64 notrap aligned v1+24
    v8 = load.i64 notrap aligned v7+16
    return_call_indirect sig1, v8(v6, v7)  ; v6 = 3

block2:
    v9 = sshr_imm.i64 v0, 3
    call fn1(v9)
    v10 = iconst.i64 3    ;; v10 :: nil
    v11 = load.i64 notrap aligned v1+24
    v12 = load.i64 notrap aligned v11+16
    return_call_indirect sig3, v12(v10, v11)  ; v10 = 3
}

