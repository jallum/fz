defmodule R do
  @type t :: opaque resource(integer)

  fn unwrap(h), do: h.value
end

extern "C" fn fz_resource_test_print_dtor(integer) :: nil

fn dwrap(x), do: fz_resource_test_print_dtor(x)

fn main() do
  a = make_resource(10, &dwrap/1)
  b = make_resource(20, &dwrap/1)
  c = make_resource(30, &dwrap/1)
  # Alias `c` into a second binding. Both bindings point at the same
  # off-heap resource; the dtor must fire exactly once when both go
  # out of scope, not twice. The MSO chain dedups by resource pointer.
  _alias = c
  # `.value` is gated to the declaring module (`R`); call it via the
  # in-module accessor. Proves the read path resolves through the
  # opaque-visibility check on all three paths.
  dbg(R.unwrap(a))
  dbg(R.unwrap(b))
  dbg(R.unwrap(c))
  dbg(:before)
end
