defprotocol Sizer do
  fn size(value)
end

defimpl Sizer, for: Integer do
  fn size(value), do: 1
end

defimpl Sizer, for: List do
  fn size(value), do: 2
end

fn describe(value), do: Sizer.size(value)

fn main() do
  case [7, [1, 2, 3], :other] do
    [a, b, c] -> describe(a) + describe(b)
    _ -> 0
  end
end
