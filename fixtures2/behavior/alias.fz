#---
# purpose: "nested-module path aliasing — `alias Long.Path` and `alias Long.Path, as: LP`"
# paths: [fz2-run, fz2-interp, fz2-build]
#---
defmodule Long do
  defmodule Path do
    fn greet(x), do: x + 1000
  end
end

defmodule User do
  alias Long.Path
  alias Long.Path, as: LP

  fn nick_name(x), do: Path.greet(x)
  fn renamed(x), do: LP.greet(x)
end

fn main() do
  assert(User.nick_name(40) == 1040, "alias Long.Path then Path.greet")
  assert(User.renamed(41) == 1041, "alias Long.Path, as: LP then LP.greet")
  assert(Long.Path.__info__(:functions) == [{:greet, 1}], "nested aliased module exports greet/1")
end
