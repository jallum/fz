#---
# purpose: "boolean operators are Elixir's `and` / `or` / `not` (no C-style `&&` / `||` / `!`) — truth table, precedence, and guard use"
# paths: [fz2-run, fz2-interp, fz2-build]
#---
#
# `and` binds tighter than `or`; `not` is the tightest unary prefix. The same
# operators are valid in `when` guards. The C-style spellings `&&` / `||` / `!`
# are not operators in fz and are rejected at lex time.
fn classify(n) when n > 0 and n < 10, do: :small
fn classify(n) when n >= 10 or n < 0, do: :big_or_negative
fn classify(_), do: :zero

fn main() do
  # Truth table for `and` / `or` / `not`.
  assert(true and true, "and: both true")
  refute(true and false, "and: one false")
  assert(true or false, "or: one true")
  refute(false or false, "or: both false")
  assert(not false, "not: negates false")
  refute(not true, "not: negates true")

  # Precedence mirrors Elixir: `and` binds tighter than `or`, and unary
  # `not` binds tightest. `true or false and false` parses as
  # `true or (false and false)`.
  assert(true or false and false, "and binds tighter than or")
  assert(not false or false, "not binds tighter than or")

  # `and` / `or` compose in guards.
  assert(classify(5) == :small, "guard: 0 < n < 10")
  assert(classify(42) == :big_or_negative, "guard: n >= 10")
  assert(classify(-1) == :big_or_negative, "guard: n < 0")
  assert(classify(0) == :zero, "guard: fall-through")
end
