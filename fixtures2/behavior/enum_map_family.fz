#---
# purpose: "Enum map-family functions match Elixir while exposing one-pass list builders to native return-demand lowering"
# paths: [fz2-run, fz2-interp, fz2-build]
# oracle: oracle.exs
# timeout.interp_secs: 15
# timeout.repl_secs: 15
#---
#
# Exercises the `fz-g58.24` Enum map family:
# `map/2`, `filter/2`, `reject/2`, `flat_map/2`, `map_reduce/3`, `scan/2,3`,
# `intersperse/2`, `with_index/1,2`, `map_every/3`, `map_join/2,3`, and
# `map_intersperse/3`.
#
# `with_index/2` covers both Elixir shapes: integer offset and function mapper.
# The mapper cases intentionally return strings, integers, and tuples so the
# fixture proves same-name/same-arity overload selection preserves the selected
# arrow's input-to-output correlation. `map_every/3` covers the `0`, `1`, and
# `> 1` step cases.
#
# The interp/repl timeout overrides keep correctness coverage while `fz-g58.52`
# owns restoring the default fixture gate.
fn main() do
  xs = [1, 2, 3, 4]
  words = ["a", "b", "c"]

  dbg(Enum.map(xs, fn (x) -> x * 2 end))
  dbg(Enum.filter(xs, fn (x) -> (x % 2) == 0 end))
  dbg(Enum.reject(xs, fn (x) -> x < 3 end))
  dbg(Enum.flat_map([1, 2, 3], fn (x) -> [x, x * 10] end))
  dbg(Enum.map_reduce(xs, 0, fn (x, acc) -> {x + acc, acc + x} end))
  dbg(Enum.scan(xs, fn (x, acc) -> x + acc end))
  dbg(Enum.scan(xs, 10, fn (x, acc) -> x + acc end))
  dbg(Enum.intersperse([1, 2, 3], 0))
  dbg(Enum.with_index(["a", "b"]))
  dbg(Enum.with_index(["a", "b"], 3))
  dbg(Enum.with_index(["a", "b"], fn (x, _index) -> x <> "!" end))
  dbg(Enum.with_index([10, 20], fn (x, index) -> x + index end))
  dbg(Enum.with_index([:a, :b], fn (x, index) -> {index, x} end))
  dbg(Enum.map_every(xs, 0, fn (x) -> x * 100 end))
  dbg(Enum.map_every(xs, 1, fn (x) -> x * 100 end))
  dbg(Enum.map_every(xs, 2, fn (x) -> x * 100 end))
  dbg(Enum.map_join(words, fn (x) -> x <> "!" end))
  dbg(Enum.map_join(words, "-", fn (x) -> x <> "!" end))
  dbg(Enum.map_intersperse(xs, :sep, fn (x) -> x * 2 end))
  dbg(Enum.map(1..7//2, fn (x) -> x + 1 end))
end
