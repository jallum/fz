#
# # receive_shared_tuple_arity
#
# Selective receive whose clauses all inspect two-element tuples. This locks down
# the shared tuple-schema matcher path used by receive matchers.
fn main() do
  send(self(), {:b, 20})
  send(self(), {:a, 10})

  x = receive do
    {:a, v} -> v + 1
    {:b, v} -> v + 2
    {:c, v} -> v + 3
  end

  y = receive do
    {:a, v} -> v + 1
    {:b, v} -> v + 2
    {:c, v} -> v + 3
  end

  assert(
    {x, y} == {22, 11},
    "same-arity tuple receive clauses keep their tag-specific arms distinct across consecutive receives"
  )
end
