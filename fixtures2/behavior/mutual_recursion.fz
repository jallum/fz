#---
# purpose: "mutual recursion — is_even/is_odd call each other; exercises cross-function recursive dispatch"
# paths: [fz2-run, fz2-interp, fz2-build]
#---
fn is_even(0), do: true
fn is_even(n), do: is_odd(n - 1)
fn is_odd(0), do: false
fn is_odd(n), do: is_even(n - 1)

fn main() do
  assert(is_even(10), "10 is even")
  assert(is_odd(7), "7 is odd")
  assert(is_even(0), "0 is even (base clause)")
  assert(is_odd(1), "1 is odd")
end
