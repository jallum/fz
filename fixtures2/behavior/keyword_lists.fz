#---
# purpose: "Elixir-style keyword lists lower to ordinary lists of atom/value tuples"
# paths: [fz2-run, fz2-interp, fz2-build]
#---
fn echo(opts), do: opts

fn main() do
  assert([a: 1, b: 2] == [{:a, 1}, {:b, 2}], "keyword list lowers to a list of atom/value tuples")
  assert(echo(timeout: 10, retry: true) == [{:timeout, 10}, {:retry, true}], "trailing keyword args collect into a keyword list")
  with_do = echo(label: :work) do
    42
  end
  assert(with_do == [{:label, :work}, {:do, 42}], "a trailing do-block becomes a :do keyword entry")
end
