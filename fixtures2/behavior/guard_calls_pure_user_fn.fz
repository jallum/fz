#---
# purpose: "case guards call pure user fns — locks X1A β-reduction three-path parity"
# paths: [fz2-run, fz2-interp, fz2-build]
#---
fn is_pos(n) do n > 0 end
fn double(x) do x * 2 end

fn classify(n) do
  case n do
    x when is_pos(x) -> :pos
    x when is_pos(double(x)) -> :zero_or_neg_doubled_pos
    _ -> :other
  end
end

fn main() do
  assert(classify(5) == :pos, "guard calling a pure user fn fires")
  assert(classify(0) == :other, "0 falls through both guards")
  assert(classify(-3) == :other, "negative falls through both guards")
end
