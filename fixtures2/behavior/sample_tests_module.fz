#---
# purpose: "`test()` inside a defmodule body"
# paths: [fz2-run, fz2-interp, fz2-build]
# kind: test
# defer.fz2-run: compiler2 does not implement `test` fixtures yet
# defer.fz2-interp: compiler2 does not implement `test` fixtures yet
# defer.fz2-build: compiler2 does not implement `test` fixtures yet
#---
defmodule MathTest do
  fn helper(x), do: x * 2

  test(:test_helper) do
    assert(helper(21) == 42)
  end

  test(:test_arithmetic) do
    assert(1 + 1 == 2)
    assert(40 + 2 == 42)
  end
end

defmodule AtomTest do
  test(:test_eq) do
    assert(:ok == :ok)
  end

  test(:test_neq) do
    refute(:ok == :error)
  end
end
