#---
# purpose: "fz-ul4.29.5 — spawn-with-captures lift (was forbidden v1)"
# paths: [fz2-run, fz2-interp, fz2-build]
#---
fn parent(tag) do
  spawn(fn () -> send(1, tag) end)
  receive do
    x -> x
  end
end

fn main() do
  assert(parent(99) == 99, "spawned closure captures tag and relays it back")
end
