#---
# purpose: "sequential calls returning tuple-pattern results (fz-i82 regression)"
# paths: [fz2-run, fz2-interp, fz2-build]
#---
fn f(v) do
  case v do
    {:ok, x} -> x
    :err -> 0
  end
end

fn g(v) do
  with {:ok, x} <- v do x else :err -> 0 end
end

fn main() do
  assert(f({:ok, 7}) == 7, "case tuple-pattern arm returns the bound value")
  assert(f(:err) == 0, "case atom fallback returns 0")
  assert(f(:err) == 0, "sequential call: atom fallback again")
  assert(f({:ok, 7}) == 7, "sequential call: tuple arm again")
  assert(g({:ok, 7}) == 7, "with tuple-pattern returns the bound value")
  assert(g(:err) == 0, "with else atom fallback returns 0")
end
