fn main() do
  xs = [1, 2, 3, 4]
  range = 1..7//2
  map = %{2 => :two, 1 => :one}

  dbg(Enum.reduce(xs, fn (x, acc) -> x * acc end))
  dbg(Enum.reduce(xs, 0, fn (x, acc) -> acc + x end))
  dbg(Enum.reduce_while(xs, 0, fn (x, acc) ->
    if x < 3 do
      {:cont, acc + x}
    else
      {:halt, acc}
    end
  end))
  dbg(Enum.each([:a, :b], fn (x) -> x end))
  dbg(Enum.count(range))
  dbg(Enum.count(xs, fn (x) -> x > 2 end))
  dbg(Enum.member?(range, 5))
  dbg(Enum.member?(range, 6))
  dbg(Enum.member?(map, {1, :one}))
  dbg(Enum.to_list(range))
  dbg(Enum.to_list(map))
  dbg(Enum.reverse(xs))
  dbg(Enum.reverse(range, [:tail]))
end
