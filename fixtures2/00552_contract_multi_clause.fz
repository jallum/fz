#---
# purpose: multi-clause dispatch and recursive fact keep their chosen clauses and continuations stable
# root: main/0
# assert.metric.semantic.activations: 3
# assert.metric.semantic.executables: 3
# assert.metric.semantic.callsites: 11
# assert.metric.call_edges.count: 11
# assert.metric.return_type.widened: 0
# assert.edge: fact/1[int] | @136-147 | direct | fact/1
# assert.edge: main/0[] | @168-179 | direct | classify/1
# assert.edge: main/0[] | @226-233 | direct | fact/1
# snapshot.call_edges: call_edges
#---
fn classify(0), do: :zero
fn classify(n) when n > 0, do: :positive
fn classify(_), do: :negative

fn fact(0), do: 1
fn fact(n), do: n * fact(n - 1)

fn main() do
  dbg(classify(0))
  dbg(classify(7))
  dbg(classify(-3))
  dbg(fact(5))
end
