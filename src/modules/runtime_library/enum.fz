defmodule Enum do
  @spec reduce(Enumerable.t(a), (a, a) -> a) :: a
  fn reduce(enumerable, reducer) do
    reduce_first_finish(
      Enumerable.reduce(enumerable, {:cont, :first}, fn (entry, state) ->
        reduce_first_step(entry, state, reducer)
      end)
    )
  end

  @spec reduce(Enumerable.t(a), b, (a, b) -> b) :: b
  fn reduce(enumerable, acc, reducer) do
    reduce_finish(
      Enumerable.reduce(enumerable, {:cont, acc}, fn (entry, inner_acc) ->
        {:cont, reducer(entry, inner_acc)}
      end)
    )
  end

  @spec reduce_while(Enumerable.t(a), b, (a, b) -> {:cont, b} | {:halt, b}) :: b
  fn reduce_while(enumerable, acc, reducer) do
    reduce_finish(Enumerable.reduce(enumerable, {:cont, acc}, reducer))
  end

  @spec each(Enumerable.t(a), (a) -> any) :: :ok
  fn each(enumerable, fun) do
    reduce(enumerable, nil, fn (entry, acc) -> each_step(entry, acc, fun) end)

    :ok
  end

  @spec count(Enumerable.t(a)) :: integer
  fn count(enumerable), do: count_result(Enumerable.count(enumerable), enumerable)

  @spec count(Enumerable.t(a), (a) -> any) :: integer
  fn count(enumerable, fun) do
    reduce(enumerable, 0, fn (entry, acc) ->
      if fun(entry), do: acc + 1, else: acc
    end)
  end

  @spec member?(Enumerable.t(a), a) :: bool
  fn member?(enumerable, value), do: member_result(Enumerable.member?(enumerable, value), enumerable, value)

  @spec to_list(Enumerable.t(a)) :: [a]
  fn to_list(enumerable), do: reverse(reverse(enumerable))

  @spec reverse(Enumerable.t(a)) :: [a]
  fn reverse(enumerable) do
    reduce(enumerable, [], fn (entry, acc) -> [entry | acc] end)
  end

  @spec reverse(Enumerable.t(a), [a]) :: [a]
  fn reverse(enumerable, tail) do
    reduce(enumerable, to_list(tail), fn (entry, acc) -> [entry | acc] end)
  end

  @spec map(Enumerable.t(a), (a) -> b) :: [b]
  fn map(enumerable, fun), do: map_list(to_list(enumerable), fun)

  @spec filter(Enumerable.t(a), (a) -> any) :: [a]
  fn filter(enumerable, fun), do: filter_list(to_list(enumerable), fun)

  @spec reject(Enumerable.t(a), (a) -> any) :: [a]
  fn reject(enumerable, fun), do: filter(enumerable, fn (entry) -> not fun(entry) end)

  @spec flat_map(Enumerable.t(a), (a) -> Enumerable.t(b)) :: [b]
  fn flat_map(enumerable, fun), do: flat_map_list(to_list(enumerable), fun)

  @spec map_reduce(Enumerable.t(a), b, (a, b) -> {c, b}) :: {[c], b}
  fn map_reduce(enumerable, acc, fun), do: map_reduce_list(to_list(enumerable), acc, fun)

  @spec scan(Enumerable.t(a), (a, a) -> a) :: [a]
  fn scan(enumerable, fun), do: scan_first(to_list(enumerable), fun)

  @spec scan(Enumerable.t(a), b, (a, b) -> b) :: [b]
  fn scan(enumerable, acc, fun), do: scan_list(to_list(enumerable), acc, fun)

  @spec intersperse(Enumerable.t(a), a) :: [a]
  fn intersperse(enumerable, separator), do: intersperse_list(to_list(enumerable), separator)

  @spec with_index(Enumerable.t(a)) :: [{a, integer}]
  fn with_index(enumerable), do: with_index(enumerable, 0)

  @spec with_index(Enumerable.t(a), integer) :: [{a, integer}]
  @spec with_index(Enumerable.t(a), (a, integer) -> b) :: [b]
  fn with_index(enumerable, offset :: integer), do: with_index_list(to_list(enumerable), offset)
  fn with_index(enumerable, fun), do: with_index_list(to_list(enumerable), 0, fun)

  @spec map_every(Enumerable.t(a), integer, (a) -> a) :: [a]
  fn map_every(enumerable, 0, _fun), do: to_list(enumerable)
  fn map_every(_enumerable, nth, _fun) when nth < 0, do: panic("Enum.OutOfBoundsError")
  fn map_every(enumerable, nth, fun), do: map_every_list(to_list(enumerable), nth, 0, fun)

  @spec map_join(Enumerable.t(a), (a) -> binary) :: binary
  fn map_join(enumerable, mapper), do: map_join(enumerable, "", mapper)

  @spec map_join(Enumerable.t(a), binary, (a) -> binary) :: binary
  fn map_join(enumerable, joiner, mapper), do: map_join_list(to_list(enumerable), joiner, mapper)

  @spec map_intersperse(Enumerable.t(a), b, (a) -> b) :: [b]
  fn map_intersperse(enumerable, separator, mapper), do: map_intersperse_list(to_list(enumerable), separator, mapper)

  @spec sort(Enumerable.t(a)) :: [a]
  fn sort(enumerable), do: sort(enumerable, fn (left, right) -> left <= right end)

  @spec sort(Enumerable.t(a), (a, a) -> bool) :: [a]
  fn sort(enumerable, sorter), do: sort_list(enumerable, sorter)

  @spec slice(Enumerable.t(a)) :: {:ok, integer, any} | {:error, any}
  fn slice(_enumerable), do: {:error, :unsupported}

  fnp reduce_finish({:done, acc}), do: acc
  fnp reduce_finish({:halted, acc}), do: acc
  fnp reduce_finish({:suspended, acc, _continuation}), do: acc

  fnp reduce_first_step(entry, :first, _reducer), do: {:cont, {:acc, entry}}
  fnp reduce_first_step(entry, {:acc, acc}, reducer), do: {:cont, {:acc, reducer(entry, acc)}}

  fnp reduce_first_finish(result), do: reduce_first_acc(reduce_finish(result))
  fnp reduce_first_acc(:first), do: panic("Enum.EmptyError")
  fnp reduce_first_acc({:acc, acc}), do: acc

  fnp each_step(entry, acc, fun) do
    fun(entry)
    acc
  end

  fnp count_result({:ok, count}, _enumerable), do: count
  fnp count_result({:error, _module}, enumerable), do: count(enumerable, fn (_entry) -> true end)

  fnp member_result({:ok, found}, _enumerable, _value), do: found
  fnp member_result({:error, _module}, enumerable, value) do
    reduce_while(enumerable, false, fn (entry, _found) ->
      if entry == value do
        {:halt, true}
      else
        {:cont, false}
      end
    end)
  end

  fnp map_list([], _fun), do: []
  fnp map_list([head | tail], fun), do: [fun(head) | map_list(tail, fun)]

  fnp filter_list([], _fun), do: []
  fnp filter_list([head | tail], fun) do
    if fun(head) do
      [head | filter_list(tail, fun)]
    else
      filter_list(tail, fun)
    end
  end

  fnp flat_map_list([], _fun), do: []
  fnp flat_map_list([head | tail], fun) do
    concat_list(to_list(fun(head)), flat_map_list(tail, fun))
  end

  fnp concat_list([], right), do: right
  fnp concat_list([head | tail], right), do: [head | concat_list(tail, right)]

  fnp map_reduce_list([], acc, _fun), do: {[], acc}
  fnp map_reduce_list([head | tail], acc, fun) do
    {mapped, next_acc} = fun(head, acc)
    {mapped_tail, final_acc} = map_reduce_list(tail, next_acc, fun)
    {[mapped | mapped_tail], final_acc}
  end

  fnp scan_first([], _fun), do: []
  fnp scan_first([head | tail], fun), do: [head | scan_list(tail, head, fun)]

  fnp scan_list([], _acc, _fun), do: []
  fnp scan_list([head | tail], acc, fun) do
    next = fun(head, acc)
    [next | scan_list(tail, next, fun)]
  end

  fnp intersperse_list([], _separator), do: []
  fnp intersperse_list([head | tail], separator), do: [head | intersperse_tail(tail, separator)]

  fnp intersperse_tail([], _separator), do: []
  fnp intersperse_tail([head | tail], separator), do: [separator, head | intersperse_tail(tail, separator)]

  fnp with_index_list([], _index), do: []
  fnp with_index_list([head | tail], index), do: [{head, index} | with_index_list(tail, index + 1)]

  fnp with_index_list([], _index, _fun), do: []
  fnp with_index_list([head | tail], index, fun), do: [fun(head, index) | with_index_list(tail, index + 1, fun)]

  fnp map_every_list([], _nth, _index, _fun), do: []
  fnp map_every_list([head | tail], nth, index, fun) do
    next = if (index % nth) == 0, do: fun(head), else: head
    [next | map_every_list(tail, nth, index + 1, fun)]
  end

  fnp map_join_list([], _joiner, _mapper), do: ""
  fnp map_join_list([head | tail], joiner, mapper) do
    map_join_tail(tail, joiner, mapper, mapper(head))
  end

  fnp map_join_tail([], _joiner, _mapper, acc), do: acc
  fnp map_join_tail([head | tail], joiner, mapper, acc) do
    map_join_tail(tail, joiner, mapper, acc <> joiner <> mapper(head))
  end

  fnp map_intersperse_list([], _separator, _mapper), do: []
  fnp map_intersperse_list([head | tail], separator, mapper) do
    [mapper(head) | map_intersperse_tail(tail, separator, mapper)]
  end

  fnp map_intersperse_tail([], _separator, _mapper), do: []
  fnp map_intersperse_tail([head | tail], separator, mapper) do
    [separator, mapper(head) | map_intersperse_tail(tail, separator, mapper)]
  end

  fnp sort_list([], _sorter), do: []
  fnp sort_list([single], _sorter), do: [single]
  fnp sort_list(list, sorter) do
    {left, right} = split_sort_list(list, [], [])
    merge_sort_lists(
      sort_list(reverse_sort_list(left), sorter),
      sort_list(reverse_sort_list(right), sorter),
      sorter
    )
  end

  fnp split_sort_list([], left, right), do: {left, right}
  fnp split_sort_list([single], left, right), do: {[single | left], right}
  fnp split_sort_list([left_head, right_head | tail], left, right) do
    split_sort_list(tail, [left_head | left], [right_head | right])
  end

  fnp reverse_sort_list(list), do: reverse_sort_list(list, [])
  fnp reverse_sort_list([], acc), do: acc
  fnp reverse_sort_list([head | tail], acc), do: reverse_sort_list(tail, [head | acc])

  fnp merge_sort_lists([], right, _sorter), do: right
  fnp merge_sort_lists(left, [], _sorter), do: left
  fnp merge_sort_lists([left_head | left_tail], [right_head | right_tail], sorter) do
    if sorter(left_head, right_head) do
      [left_head | merge_sort_lists(left_tail, [right_head | right_tail], sorter)]
    else
      [right_head | merge_sort_lists([left_head | left_tail], right_tail, sorter)]
    end
  end
end
