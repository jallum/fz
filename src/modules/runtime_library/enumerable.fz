defmodule Enumerable do
  extern "C" fn fz_map_count(any) :: integer
  extern "C" fn fz_map_entry_key(any, integer) :: any
  extern "C" fn fz_map_entry_value(any, integer) :: any

  defprotocol Enumerable do
    @spec reduce(t(a), b, (a, b) -> {:cont, b} | {:halt, b} | {:suspend, b}) :: any
    fn reduce(enumerable, acc, reducer)

    @spec count(t(a)) :: {:ok, integer} | {:error, any}
    fn count(enumerable)

    @spec member?(t(a), a) :: {:ok, bool} | {:error, any}
    fn member?(enumerable, value)

    @spec slice(t(a)) :: {:ok, integer, any} | {:error, any}
    fn slice(enumerable)
  end

  defimpl Enumerable, for: List do
    fn reduce(list, acc, reducer), do: Enumerable.reduce_list(list, acc, reducer)

    fn count(list), do: {:ok, Enumerable.count_list(list, 0)}
    fn member?(list, value), do: {:ok, Enumerable.member_list?(list, value)}
    fn slice(_list), do: {:error, :unsupported}
  end

  defimpl Enumerable, for: Range do
    fn reduce(%Range{first: first, last: last, step: step}, acc, reducer) do
      Enumerable.reduce_range(first, last, step, acc, reducer)
    end

    fn count(%Range{first: first, last: last, step: step}) do
      {:ok, Enumerable.count_range(first, last, step)}
    end

    fn member?(%Range{first: first, last: last, step: step}, value) do
      {:ok, Enumerable.member_range?(first, last, step, value)}
    end

    fn slice(%Range{first: first, last: last, step: step}) do
      {:ok, Enumerable.count_range(first, last, step), (fn (start, amount, stride) -> Enumerable.slice_range(first, last, step, start, amount, stride) end)}
    end
  end

  defimpl Enumerable, for: Map do
    fn reduce(map, acc, reducer) do
      Enumerable.reduce_map(map, Enumerable.fz_map_count(map), acc, reducer)
    end

    fn count(map) do
      {:ok, Enumerable.fz_map_count(map)}
    end

    fn member?(map, pair) do
      {:ok, Enumerable.member_map?(map, Enumerable.fz_map_count(map), pair)}
    end

    fn slice(map) do
      {:ok, Enumerable.fz_map_count(map), (fn (_map) -> Enumerable.map_to_list(map) end)}
    end
  end

  fn reduce_list(list, {:cont, acc}, reducer), do: reduce_list_cont(list, acc, reducer)
  fn reduce_list(_list, {:halt, acc}, _reducer), do: {:halted, acc}
  fn reduce_list(list, {:suspend, acc}, reducer) do
    {:suspended, acc, (fn () -> reduce_list_cont(list, acc, reducer) end)}
  end

  fn reduce_list_cont([], acc, _reducer), do: {:done, acc}
  fn reduce_list_cont([h | t], acc, reducer) do
    reduce_list_step(t, reducer(h, acc), reducer)
  end

  fn reduce_list_step(list, {:cont, acc}, reducer), do: reduce_list_cont(list, acc, reducer)
  fn reduce_list_step(_list, {:halt, acc}, _reducer), do: {:halted, acc}
  fn reduce_list_step(list, {:suspend, acc}, reducer) do
    {:suspended, acc, (fn () -> reduce_list_cont(list, acc, reducer) end)}
  end

  fn count_list([], acc), do: acc
  fn count_list([_ | t], acc), do: count_list(t, acc + 1)

  fn member_list?([], _value), do: false
  fn member_list?([h | _], value) when h == value, do: true
  fn member_list?([_ | t], value), do: member_list?(t, value)

  fn reduce_map(map, count, {:cont, acc}, reducer), do: reduce_map_cont(map, count, 0, acc, reducer)
  fn reduce_map(_map, _count, {:halt, acc}, _reducer), do: {:halted, acc}
  fn reduce_map(map, count, {:suspend, acc}, reducer) do
    {:suspended, acc, (fn () -> reduce_map_cont(map, count, 0, acc, reducer) end)}
  end

  fn reduce_map_cont(_map, count, index, acc, _reducer) when index >= count, do: {:done, acc}
  fn reduce_map_cont(map, count, index, acc, reducer) do
    reduce_map_step(map, count, index, reducer(map_entry(map, index), acc), reducer)
  end

  fn reduce_map_step(map, count, index, {:cont, acc}, reducer), do: reduce_map_cont(map, count, index + 1, acc, reducer)
  fn reduce_map_step(_map, _count, _index, {:halt, acc}, _reducer), do: {:halted, acc}
  fn reduce_map_step(map, count, index, {:suspend, acc}, reducer) do
    {:suspended, acc, (fn () -> reduce_map_cont(map, count, index + 1, acc, reducer) end)}
  end

  fn member_map?(map, count, {key, value}), do: member_map_pair?(map, count, 0, key, value)
  fn member_map?(_map, _count, _value), do: false

  fn member_map_pair?(_map, count, index, _key, _value) when index >= count, do: false
  fn member_map_pair?(map, count, index, key, value) do
    if fz_map_entry_key(map, index) == key && fz_map_entry_value(map, index) == value do
      true
    else
      member_map_pair?(map, count, index + 1, key, value)
    end
  end

  fn map_entry(map, index) do
    {fz_map_entry_key(map, index), fz_map_entry_value(map, index)}
  end

  fn map_to_list(map), do: map_to_list(map, fz_map_count(map), 0, [])
  fn map_to_list(_map, count, index, acc) when index >= count, do: reverse_list(acc, [])
  fn map_to_list(map, count, index, acc), do: map_to_list(map, count, index + 1, [map_entry(map, index) | acc])

  fn reduce_range(first, last, step, {:cont, acc}, reducer), do: reduce_range_cont(first, last, step, first, acc, reducer)
  fn reduce_range(_first, _last, _step, {:halt, acc}, _reducer), do: {:halted, acc}
  fn reduce_range(first, last, step, {:suspend, acc}, reducer) do
    {:suspended, acc, (fn () -> reduce_range_cont(first, last, step, first, acc, reducer) end)}
  end

  fn reduce_range_cont(_first, last, step, current, acc, _reducer) when (step > 0 && current > last), do: {:done, acc}
  fn reduce_range_cont(_first, last, step, current, acc, _reducer) when (step < 0 && current < last), do: {:done, acc}
  fn reduce_range_cont(first, last, step, current, acc, reducer) do
    reduce_range_step(first, last, step, current, reducer(current, acc), reducer)
  end

  fn reduce_range_step(first, last, step, current, {:cont, acc}, reducer), do: reduce_range_cont(first, last, step, current + step, acc, reducer)
  fn reduce_range_step(_first, _last, _step, _current, {:halt, acc}, _reducer), do: {:halted, acc}
  fn reduce_range_step(first, last, step, current, {:suspend, acc}, reducer) do
    {:suspended, acc, (fn () -> reduce_range_cont(first, last, step, current + step, acc, reducer) end)}
  end

  fn count_range(first, last, step) when (step > 0 && first > last), do: 0
  fn count_range(first, last, step) when (step < 0 && first < last), do: 0
  fn count_range(first, last, step), do: (abs_int(last - first) / abs_int(step)) + 1

  fn member_range?(first, last, step, _value) when (step > 0 && first > last), do: false
  fn member_range?(first, last, step, _value) when (step < 0 && first < last), do: false
  fn member_range?(first, last, step, value) when (step > 0 && value >= first && value <= last), do: ((value - first) % step) == 0
  fn member_range?(first, last, step, value) when (step < 0 && value <= first && value >= last), do: ((value - first) % step) == 0
  fn member_range?(_first, _last, _step, _value), do: false

  fn slice_range(first, last, step, start, amount, stride) do
    slice_range_from(last, step + stride - 1, first + (start * step), amount, [])
  end

  fn slice_range_from(_last, _step, _current, 0, acc), do: reverse_list(acc, [])
  fn slice_range_from(last, step, current, _amount, acc) when (step > 0 && current > last), do: reverse_list(acc, [])
  fn slice_range_from(last, step, current, _amount, acc) when (step < 0 && current < last), do: reverse_list(acc, [])
  fn slice_range_from(last, step, current, amount, acc), do: slice_range_from(last, step, current + step, amount - 1, [current | acc])

  fn reverse_list([], acc), do: acc
  fn reverse_list([head | tail], acc), do: reverse_list(tail, [head | acc])

  fnp abs_int(value) when value < 0, do: 0 - value
  fnp abs_int(value), do: value
end
