defmodule List do
  @moduledoc "List helpers used by operator desugaring."

  @doc "Concatenates two lists."
  @spec concat([a], [a]) :: [a]
  fn concat([], right), do: right
  fn concat([head | tail], right), do: [head | concat(tail, right)]

  @doc "Removes the first matching left-side item for each item in the right list."
  @spec subtract([a], [a]) :: [a]
  fn subtract(left, []), do: left
  fn subtract(left, [item | rest]), do: subtract(delete_first(left, item), rest)

  fnp delete_first([], _value), do: []
  fnp delete_first([head | tail], value) when head == value, do: tail
  fnp delete_first([head | tail], value), do: [head | delete_first(tail, value)]
end
