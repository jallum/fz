defmodule Utf8 do
  @moduledoc "UTF-8 validation and branding for byte-aligned binaries."

  extern "C" fn fz_bitstring_valid_utf8(any) :: integer
  extern "C" fn fz_brand_bitstring_as_utf8(any) :: any

  @doc "Returns true for byte-aligned valid UTF-8."
  @spec valid?(binary) :: bool
  fn valid?(bytes), do: fz_bitstring_valid_utf8(bytes) == 1

  @doc "Returns a UTF-8 value or aborts."
  @spec from_bytes!(binary) :: utf8
  fn from_bytes!(bytes) do
    assert(valid?(bytes))
    fz_brand_bitstring_as_utf8(bytes)
  end

  @doc "Returns {:ok, utf8} or {:error, :invalid_utf8}."
  @spec from_bytes(binary) :: {:ok, utf8} | {:error, :invalid_utf8}
  fn from_bytes(bytes) do
    if valid?(bytes) do
      {:ok, fz_brand_bitstring_as_utf8(bytes)}
    else
      {:error, :invalid_utf8}
    end
  end

  @doc "Returns the underlying binary."
  @spec to_bytes(utf8) :: binary
  fn to_bytes(s), do: s
end
