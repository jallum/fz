@type pid :: opaque integer
@type ref :: opaque cpointer
# fz-axu.12 (S1) -- utf8 is a brand on binary. String literal
# lowering mints this unqualified runtime-prelude brand directly, so it
# must stay root-scoped even as the Utf8 helpers live in a module.
@type utf8 :: refines binary

defmodule Utf8 do
  extern "C" fn fz_bitstring_valid_utf8(any) :: integer
  extern "C" fn fz_brand_bitstring_as_utf8(any) :: any

  @doc "True iff `bytes` is a valid UTF-8 byte-aligned bitstring."
  @spec valid?(any) :: bool
  fn valid?(bytes), do: fz_bitstring_valid_utf8(bytes) == 1

  @doc "Wrap `bytes` as utf8; aborts if `bytes` is not valid UTF-8."
  @spec from_bytes!(any) :: any
  fn from_bytes!(bytes) do
    assert(valid?(bytes))
    fz_brand_bitstring_as_utf8(bytes)
  end

  @doc "Wrap `bytes` as utf8; returns {:ok, utf8} or {:error, :invalid_utf8}."
  @spec from_bytes(any) :: any
  fn from_bytes(bytes) do
    if valid?(bytes) do
      {:ok, fz_brand_bitstring_as_utf8(bytes)}
    else
      {:error, :invalid_utf8}
    end
  end

  @doc "Unwrap a utf8 value back to its underlying binary."
  @spec to_bytes(any) :: any
  fn to_bytes(s), do: s
end

defmodule Process do
  extern "C" fn fz_process_heap_alloc_stats() :: any

  @doc "Returns current-process allocation counters collected since the process statistics reset point."
  @spec heap_alloc_stats() :: any
  fn heap_alloc_stats(), do: fz_process_heap_alloc_stats()
end

defmodule Kernel do
  extern "C" fn fz_print_i64(integer) :: nil
  extern "C" fn fz_print_value(any) :: nil
  extern "C" fn fz_assert(any) :: nil
  extern "C" fn fz_assert_eq(any, any) :: nil
  extern "C" fn fz_assert_neq(any, any) :: nil
  extern "C" fn fz_spawn(() -> any) :: pid
  extern "C" fn fz_spawn_opt(() -> any, any) :: pid
  extern "C" fn fz_self() :: pid
  extern "C" fn fz_send(pid, t) :: t when t: any
  extern "C" fn fz_make_ref() :: ref
  extern "C" fn fz_make_resource(t, (t) -> nil) :: resource(t) when t: integer | cpointer
end

@doc "Prints x to standard output."
@spec print(any) :: nil
fn print(x :: integer), do: Kernel.fz_print_i64(x)
fn print(x), do: Kernel.fz_print_value(x)

@doc "Aborts the process if x is falsy (nil or false)."
@spec assert(any) :: nil
fn assert(x), do: Kernel.fz_assert(x)

@doc "Aborts the process if a and b are not equal."
@spec assert_eq(any, any) :: nil
fn assert_eq(a, b), do: Kernel.fz_assert_eq(a, b)

@doc "Aborts the process if a and b are equal."
@spec assert_neq(any, any) :: nil
fn assert_neq(a, b), do: Kernel.fz_assert_neq(a, b)

@doc "Returns the process identifier of a new process started by the application of fun"
fn spawn(fun), do: Kernel.fz_spawn(fun)
fn spawn(fun, opts), do: Kernel.fz_spawn_opt(fun, opts)

@doc "Returns the PID of the calling process."
@spec self() :: pid
fn self(), do: Kernel.fz_self()

@doc "Sends msg to the process identified by pid; returns msg."
@spec send(pid, t) :: t when t: any
fn send(pid, msg), do: Kernel.fz_send(pid, msg)

@doc "Mints a fresh opaque reference unique within this runtime process."
@spec make_ref() :: ref
fn make_ref(), do: Kernel.fz_make_ref()

@doc "Wraps a raw integer handle in an opaque resource; `dtor` is invoked exactly once with that handle when the last reference becomes unreachable."
@spec make_resource(t, (t) -> nil) :: resource(t) when t: integer | cpointer
fn make_resource(value, dtor), do: Kernel.fz_make_resource(value, dtor)
