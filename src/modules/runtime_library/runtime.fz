@type keyword() :: [{atom, any}]
@type keyword(t) :: [{atom, t}]

alias Enum
alias Enumerable
alias Kernel
alias List
alias Map
alias Process
alias Range
alias Utf8

import Kernel, only: [
  +: 2,
  -: 2,
  *: 2,
  /: 2,
  %: 2,
  assert: 1,
  assert: 2,
  dbg: 1,
  make_ref: 0,
  make_resource: 2,
  panic: 1,
  range: 3,
  refute: 1,
  refute: 2,
  self: 0,
  send: 2,
  spawn: 1,
  spawn: 2
]

defmacro fn(source) do
  quote do: Fz.Compiler.define(unquote(source), unquote(__CALLER__))
end

defmacro fnp(source) do
  quote do: Fz.Compiler.define(unquote(source), unquote(__CALLER__))
end

defmacro defmacro(source) do
  quote do: Fz.Compiler.define(unquote(source), unquote(__CALLER__))
end
