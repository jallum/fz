@type pid :: opaque integer
@type ref :: opaque integer
# fz-axu.12 (S1) — utf8 is a brand on binary. The L3 desugaring pass
# mints values of this brand for every `"…"` literal that's valid
# UTF-8. As an unqualified runtime-prelude brand it has no module
# owner, so any user code can mint and use it without import.
@type utf8 :: refines binary

# fz-axu.12 (S1) / .13 (S2) — Utf8: convenience surface around the
# `utf8` brand. The runtime externs (R1, fz-axu.14) do the actual
# validation and brand-mint; these functions wire them into the user
# language.
defmodule Utf8 do
  @doc "True iff `bytes` is a valid UTF-8 byte-aligned bitstring."
  @spec valid?(any) :: bool
  fn valid?(bytes), do: fz_bitstring_valid_utf8(bytes) == 1

  @doc "Wrap `bytes` as utf8; aborts if `bytes` is not valid UTF-8."
  @spec from_bytes!(any) :: any
  fn from_bytes!(bytes) do
    assert(valid?(bytes))
    fz_brand_bitstring_as_utf8(bytes)
  end

  @doc "Wrap `bytes` as utf8; returns {:ok, utf8} or {:error, :invalid_utf8}."
  @spec from_bytes(any) :: any
  fn from_bytes(bytes) do
    if valid?(bytes) do
      {:ok, fz_brand_bitstring_as_utf8(bytes)}
    else
      {:error, :invalid_utf8}
    end
  end

  @doc "Unwrap a utf8 value back to its underlying binary."
  @spec to_bytes(any) :: any
  fn to_bytes(s), do: s
end

@doc "Prints x to standard output."
@spec print(any) :: nil
fn print(x :: integer), do: fz_print_i64(x)
fn print(x), do: fz_print_value(x)

@doc "Aborts the process if x is falsy (nil or false)."
@spec assert(any) :: nil
fn assert(x), do: fz_assert(x)

@doc "Aborts the process if a and b are not equal."
@spec assert_eq(any, any) :: nil
fn assert_eq(a, b), do: fz_assert_eq(a, b)

@doc "Aborts the process if a and b are equal."
@spec assert_neq(any, any) :: nil
fn assert_neq(a, b), do: fz_assert_neq(a, b)

@doc "Returns element i of vector v (zero-based index)."
@spec vec_get(any, integer) :: any
fn vec_get(v :: vector(integer), i), do: fz_vec_get(v, i)
fn vec_get(v, i), do: fz_vec_get(v, i)

@doc "Returns the PID of the calling process."
@spec self() :: pid
fn self(), do: fz_self()

@doc "Sends msg to the process identified by pid; returns msg."
@spec send(pid, any) :: any
fn send(pid, msg), do: fz_send(pid, msg)

@doc "Mints a fresh opaque reference unique within this runtime process."
@spec make_ref() :: ref
fn make_ref(), do: fz_make_ref()

@doc "Wraps `value` in an opaque resource; `dtor` is invoked exactly once when the last reference becomes unreachable (interp: at GC sweep / process heap drop)."
@spec make_resource(any, any) :: any
fn make_resource(value, dtor), do: fz_make_resource(value, dtor)

extern "C" fn fz_print_i64(integer) :: nil
extern "C" fn fz_print_value(any) :: nil
extern "C" fn fz_assert(any) :: nil
extern "C" fn fz_assert_eq(any, any) :: nil
extern "C" fn fz_assert_neq(any, any) :: nil
extern "C" fn fz_vec_get(any, any) :: any
extern "C" fn fz_spawn(any) :: any
extern "C" fn fz_spawn_opt(any, any) :: any
extern "C" fn fz_self() :: pid
extern "C" fn fz_send(pid, any) :: any
extern "C" fn fz_make_ref() :: ref
extern "C" fn fz_make_resource(any, any) :: any
extern "C" fn fz_bitstring_valid_utf8(any) :: integer
extern "C" fn fz_brand_bitstring_as_utf8(any) :: any
