# The real Enum.reduce shape, no protocol: a {:cont, acc} | {:halt, acc} state
# threaded through the fold, a {:done, acc} | {:halted, acc} result, a `finish`
# unwrap, and the wrapper closure `fn (e,i) -> {:cont, f.(e,i)}` capturing the
# reducer. Same nested-closure shape as fold_capture_closure: the captured
# reducer closure is just another concrete capture.
#
# Expected: myreduce([1,2,3], 0, +) : number ; settles.

fn finish(state) do
  case state do
    {:done, acc} -> acc
    {:halted, acc} -> acc
  end
end

fn loop(list, state, f) do
  case state do
    {:halt, acc} -> {:halted, acc}
    {:cont, acc} ->
      case list do
        [] -> {:done, acc}
        [h | t] -> loop(t, f.(h, acc), f)
      end
  end
end

fn myreduce(list, acc, f) do
  finish(loop(list, {:cont, acc}, fn (entry, inner) -> {:cont, f.(entry, inner)} end))
end

fn main() do
  dbg(myreduce([1, 2, 3], 0, fn (x, a) -> x + a end))
end
