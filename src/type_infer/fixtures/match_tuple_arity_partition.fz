# Tuple partition by arity. The one-field and two-field tuple arms project
# different payload shapes, while the atom arm stays disjoint; impossible arities
# must not contribute `any` or extra fields.
#
# Expected: main() : {int, {int, int}, :other}

fn pick({:one, x}), do: x
fn pick({:two, x, y}), do: {x, y}
fn pick(:other), do: :other

fn main() do
  {pick({:one, 1}), pick({:two, 1, 2}), pick(:other)}
end
