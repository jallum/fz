# Non-tail wrapper over the recursive fold: `finish(go(...))` consumes go's result,
# so go's call carries a continuation. Still settles — the continuation receives a
# concrete `number`.
#
# Expected: myreduce([1,2,3], 0, +) : number ; settles.

fn finish(x) do
  x
end

fn go(list, acc, f) do
  case list do
    [] -> acc
    [h | t] -> go(t, f.(h, acc), f)
    _ -> acc
  end
end

fn myreduce(list, acc, f) do
  finish(go(list, acc, f))
end

fn main() do
  dbg(myreduce([1, 2, 3], 0, fn (x, a) -> x + a end))
end
